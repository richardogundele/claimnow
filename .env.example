# =============================================================================
# ClaimsNOW - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# The .gitignore file should exclude .env files.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Credentials
# -----------------------------------------------------------------------------
# Option 1: Set explicit credentials (for local development)
# Option 2: Leave blank to use IAM roles (recommended for production)

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=eu-west-2

# -----------------------------------------------------------------------------
# S3 Configuration - Document Storage
# -----------------------------------------------------------------------------
# The S3 bucket must exist before running the application.
# Create it in the AWS Console or via CLI:
#   aws s3 mb s3://your-bucket-name --region eu-west-2

S3_BUCKET_NAME=claimsnow-documents
S3_UPLOAD_PREFIX=uploads/
S3_RESULTS_PREFIX=results/

# -----------------------------------------------------------------------------
# DynamoDB Configuration - Database
# -----------------------------------------------------------------------------
# Tables must be created before running. See /docs/dynamodb-setup.md

DYNAMODB_RATES_TABLE=claimsnow-market-rates
DYNAMODB_CLAIMS_TABLE=claimsnow-claims

# -----------------------------------------------------------------------------
# Textract Configuration
# -----------------------------------------------------------------------------
# Maximum pages to process per document (controls costs)

TEXTRACT_MAX_PAGES=50

# -----------------------------------------------------------------------------
# Bedrock Configuration - Claude AI
# -----------------------------------------------------------------------------
# Ensure Bedrock model access is enabled in your AWS account.
# See: AWS Console > Bedrock > Model Access

BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# Scoring Thresholds
# -----------------------------------------------------------------------------
# Adjust these based on your business rules.
# THRESHOLD_FAIR: Claims with inflation ratio below this are FAIR
# THRESHOLD_INFLATED: Claims between FAIR and this are POTENTIALLY_INFLATED
# Claims above THRESHOLD_INFLATED are FLAGGED

THRESHOLD_FAIR=1.1
THRESHOLD_INFLATED=1.4

# -----------------------------------------------------------------------------
# Confidence Score Weights
# -----------------------------------------------------------------------------
# How much each field contributes to overall confidence.
# Should sum to 1.0 (100%)

CONFIDENCE_WEIGHT_HIRE_DATES=0.20
CONFIDENCE_WEIGHT_VEHICLE_CLASS=0.15
CONFIDENCE_WEIGHT_DAILY_RATE=0.30
CONFIDENCE_WEIGHT_TOTAL_CLAIMED=0.20
CONFIDENCE_WEIGHT_HIRE_COMPANY=0.15

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Settings for the FastAPI server

API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# CORS origins for frontend (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
